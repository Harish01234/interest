
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Todo {
  id        Int      @id @default(autoincrement())
  title     String
  createdAt DateTime @default(now())
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]
  members       Member[]
  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

enum MemberType {
  gold
  silver
  both
  unknown
}

model Member {
  id         Int        @id @default(autoincrement())
  slNo       String
  name       String
  fatherName String
  credit     String
  date       String
  phoneNo    String
  type       MemberType @default(unknown)
  jinsis     String?
  interest   Int        @default(0)
  active     Boolean    @default(true)
  settledAt  DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)  

  @@index([slNo])
  @@index([active])
  @@index([active, slNo])
  @@index([settledAt])
  @@map("member")
}


model Calculation {
  id              Int       @id @default(autoincrement())
  TotalTobill     Int       @default(0)
  Asol            Int       @default(0) // sum(credit) of members settled after periodStartedAt
  Interest        Int       @default(0) // sum(interest) of members settled after periodStartedAt
  Dewa            Int       @default(0) // sum(credit) of members added after periodStartedAt

  CashInHome      Int       @default(0)
  CashInShop      Int       @default(0)
  cashToPersons   Json      @default("[]") // [{ "name": "Ali", "amount": 5000 }, ...]

  periodStartedAt DateTime? // stamped when TotalTobill is set; anchors the period

  CreatedAt       DateTime  @default(now())
  UpdatedAt       DateTime  @updatedAt

  @@map("calculation")
}

//if sum(TotalTobill+asol+interest-dewa===cashInHome+cashInShop+cashToPersons) then calculation is correct otherwise it is incorrect


model MainCalculation {
  id Int @id @default(autoincrement())
  TotalTobill Int
  interest Int
  Bandak Int
  jinisChara Int
  cash Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("main_calculation")
}

